# Terraform working directory
.terraform/
.terraform.lock.hcl

# Terraform state files (VERY IMPORTANT to ignore)
*.tfstate
*.tfstate.*
*.tfplan

# Crash logs
crash.log
day_16/test/terratest.log
day_18/test/terratest.log

# Sensitive variable files
*.tfvars
*.tfvars.json

# Day 25 lab tfvars contains only non-sensitive demo inputs.
!day_25/day25-static-website/envs/dev/terraform.tfvars

# Day 26 lab tfvars contains only non-sensitive demo inputs.
!day_26/day26-scalable-web-app/envs/dev/terraform.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config files
.terraformrc
terraform.rc

# OS files
.DS_Store
Thumbs.db

# Codex workspace file
.codex

