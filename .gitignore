# Terraform working directory
.terraform/
.terraform.lock.hcl

# Terraform state files (VERY IMPORTANT to ignore)
*.tfstate
*.tfstate.*

# Crash logs
crash.log
day_16/test/terratest.log

# Sensitive variable files
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config files
.terraformrc
terraform.rc

# OS files
.DS_Store
Thumbs.db

# Codex workspace file
.codex

# Allow today's lock file to be committed for Day 14 provider version tracking
!day_14/.terraform.lock.hcl

# Allow today's lock file to be committed for Day 16 production-grade refactor
!day_16/examples/hello-world-app/.terraform.lock.hcl

# Allow today's lock files to be committed for Day 17 manual testing environments
!day_17/environments/dev/.terraform.lock.hcl
!day_17/environments/production/.terraform.lock.hcl
